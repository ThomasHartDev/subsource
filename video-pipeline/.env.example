# Cheap path needs no env vars (Claude Code CLI on PATH + msedge-tts is keyless)

# Premium / Veo path
FAL_API_KEY=               # fal.ai key, format: <uuid>:<hex>
CARTESIA_API_KEY=          # Cartesia Sonic-3 TTS, format: sk_car_...
GOAPI_KEY=                 # GoAPI Suno music (optional, falls back to Stable Audio)
REPLICATE_API_KEY=         # Replicate Stable Audio fallback (optional)

# Stock footage path (free)
PEXELS_API_KEY=            # https://www.pexels.com/api/
PIXABAY_API_KEY=           # https://pixabay.com/api/docs/

# Legacy / unused but referenced in some services
ELEVENLABS_API_KEY=        # alternative to Cartesia, not preferred
GOOGLE_AI_STUDIO_API_KEY=  # legacy gemini path, replaced by fal Veo
